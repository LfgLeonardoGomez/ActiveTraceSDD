# activia-trace — Variables de entorno
# Copiar a .env y rellenar con valores reales. NUNCA commitear .env con secretos.

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/activia_trace

# JWT
SECRET_KEY=replace-with-min-32-char-secret-key-here-x
ACCESS_TOKEN_EXPIRE_MINUTES=15

# AES-256 para PII/secretos (exactamente 32 caracteres)
ENCRYPTION_KEY=replace-with-exactly-32-char-key-h

# Test database
DATABASE_URL_TEST=postgresql+asyncpg://user:password@localhost:5432/activia_trace_test

# OpenTelemetry (opcional)
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=activia-trace
